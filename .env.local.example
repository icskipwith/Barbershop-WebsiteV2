# -------------------------------------------------------
# COPY this file to .env.local and fill in your values.
# .env.local is gitignored — your secrets stay off GitHub.
# -------------------------------------------------------

# Your Stripe SECRET key (starts with sk_test_ for test mode)
# Find it at: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# The full URL of your site (no trailing slash)
# Local:      http://localhost:3002
# Production: https://your-project.vercel.app
NEXT_PUBLIC_BASE_URL=http://localhost:3002
